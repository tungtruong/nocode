# Thêm DeepSeek API key để dùng AI sinh app chất lượng cao
# Lấy key tại: https://platform.deepseek.com/api_keys
# Nếu không có key, hệ thống sẽ dùng fallback template có sẵn
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Optional fallback. If DeepSeek times out or returns 5xx, the server retries
# the same call on OpenAI. Leave blank to disable fallback (DeepSeek errors
# propagate as-is). gpt-4o-mini is cheap and supports tool use; gpt-4o is
# stronger but ~10x the price.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Required: signing key cho JWT session cookie. Random ≥32 bytes (openssl rand -base64 32)
AUTH_SECRET=

# Public base URL (dùng để build deployed app URLs trong /api/deploy)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Dev only: cho phép cookie qua HTTP (mặc định cookie là Secure → cần HTTPS)
# Để rỗng hoặc bỏ ở production.
DEV_INSECURE_COOKIE=true

# Production opt-in: cho phép mock users (demo@nocode.dev / admin@nocode.dev) chạy
# trong môi trường production. Mặc định = false. Đừng bật trừ khi bạn cố tình.
# ALLOW_MOCK_AUTH=false

# === Stripe (test mode) ===
# 1. Tạo tài khoản: https://dashboard.stripe.com/register (verify email là chạy được test mode)
# 2. Lấy keys: https://dashboard.stripe.com/test/apikeys
# 3. Tạo 2 Products + recurring monthly Prices ở https://dashboard.stripe.com/test/products
#    - "nocode Pro" $12/month → STRIPE_PRICE_PRO=price_xxx
#    - "nocode Team" $39/month → STRIPE_PRICE_TEAM=price_xxx
# 4. Webhook: https://dashboard.stripe.com/test/webhooks → Add endpoint
#    URL: https://<your-domain>/api/webhooks/stripe
#    Events: checkout.session.completed, customer.subscription.created/updated/deleted, invoice.payment_failed
#    Sao chép "Signing secret" → STRIPE_WEBHOOK_SECRET
# Local test webhook: dùng Stripe CLI:
#   stripe listen --forward-to localhost:3002/api/webhooks/stripe
#   → CLI print whsec_... — paste vào STRIPE_WEBHOOK_SECRET
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === Google OAuth ===
# 1. Vào https://console.cloud.google.com → tạo project (hoặc dùng có sẵn)
# 2. APIs & Services → OAuth consent screen → External → điền các trường bắt buộc,
#    add "userinfo.email" và "userinfo.profile" + "openid" scopes
# 3. Credentials → Create Credentials → OAuth client ID → Application type = Web
# 4. Authorized redirect URIs:
#    - http://localhost:3002/api/auth/google/callback    (dev)
#    - https://<your-domain>/api/auth/google/callback    (prod)
# 5. Sao chép Client ID + Client Secret
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
