# Thêm DeepSeek API key để dùng AI sinh app chất lượng cao
# Lấy key tại: https://platform.deepseek.com/api_keys
# Nếu không có key, hệ thống sẽ dùng fallback template có sẵn
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Optional fallback. If DeepSeek times out or returns 5xx, the server retries
# the same call on OpenAI. Leave blank to disable fallback (DeepSeek errors
# propagate as-is). gpt-4o-mini is cheap and supports tool use; gpt-4o is
# stronger but ~10x the price.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Required: signing key cho JWT session cookie. Random ≥32 bytes (openssl rand -base64 32)
AUTH_SECRET=

# Public base URL (dùng để build deployed app URLs trong /api/deploy)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Wildcard subdomain cho deployed apps (CF DNS: *.justvibe.me → server).
# Khi set, mỗi app deploy nhận URL <slug>.justvibe.me. Bỏ trống để fallback
# về `/apps/<id>` path-based URL (dev hoặc khi chưa setup wildcard DNS).
# APPS_DOMAIN=justvibe.me

# Dev only: cho phép cookie qua HTTP (mặc định cookie là Secure → cần HTTPS)
# Để rỗng hoặc bỏ ở production.
DEV_INSECURE_COOKIE=true

# Production opt-in: cho phép mock users (demo@nocode.dev / admin@nocode.dev) chạy
# trong môi trường production. Mặc định = false. Đừng bật trừ khi bạn cố tình.
# ALLOW_MOCK_AUTH=false

# === PayPal Subscriptions ===
# (Vietnam doesn't qualify for Stripe yet, so we use PayPal.)
#
# 1. Đăng ký Business account: https://www.paypal.com/vn/business
#    Sandbox testing: tự động được tạo cùng tài khoản developer
#    Dashboard: https://developer.paypal.com/dashboard/applications/sandbox
# 2. Apps & Credentials → Create App → "REST API" → lấy Client ID + Secret
# 3. Tạo Subscription Plans (tự nhiên qua API, hoặc qua Dashboard):
#    - Products → Add product (Name "nocode Pro", Type "Service")
#    - Pricing & plans → Add plan: Monthly $12, Auto renew
#    - Sao chép Plan ID (vd P-XXXXXXXXXXXXXXX) → PAYPAL_PLAN_PRO
#    - Lặp lại cho Team $39 → PAYPAL_PLAN_TEAM
# 4. Webhook: https://developer.paypal.com/dashboard/webhooks (sandbox)
#    URL: https://<your-domain>/api/webhooks/paypal
#    Events: subscribe to BILLING.SUBSCRIPTION.* + PAYMENT.SALE.COMPLETED
#    Sao chép Webhook ID → PAYPAL_WEBHOOK_ID
#    (Local test: dùng ngrok hoặc PayPal CLI để tunnel)
# 5. Set PAYPAL_MODE=sandbox khi test, =live khi production.
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_PLAN_PRO=P-...
# PAYPAL_PLAN_TEAM=P-...
# PAYPAL_WEBHOOK_ID=...
# PAYPAL_MODE=sandbox

# === Google OAuth ===
# 1. Vào https://console.cloud.google.com → tạo project (hoặc dùng có sẵn)
# 2. APIs & Services → OAuth consent screen → External → điền các trường bắt buộc,
#    add "userinfo.email" và "userinfo.profile" + "openid" scopes
# 3. Credentials → Create Credentials → OAuth client ID → Application type = Web
# 4. Authorized redirect URIs:
#    - http://localhost:3002/api/auth/google/callback    (dev)
#    - https://<your-domain>/api/auth/google/callback    (prod)
# 5. Sao chép Client ID + Client Secret
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
